<%
  set_meta_tags(
    title: "Model",
    description: "Renders one model of the user",
    keywords: "Model"
  )
%>

<div class="container max-w-screen-lg my-4">
  <div class="row">
    <div class="col-12 col-lg-3 mt-3 mt-lg-0">
      <%= render "model/definitions/show/variables", model: model %>
    </div>
    <div class="col-12 col-lg-9 mt-3 mt-lg-0">
      <%= render "model/definitions/show/chart" %>
    </div>
  </div>
</div>
